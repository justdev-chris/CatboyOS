# CatboyOS fetch script. Meow.

# в”Ђв”Ђв”Ђ COLORS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
reset='\033[0m'
bold='\033[1m'
red='\033[31m'
green='\033[32m'
yellow='\033[33m'
blue='\033[34m'
magenta='\033[35m'
cyan='\033[36m'
white='\033[37m'

# в”Ђв”Ђв”Ђ ASCII CAT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cat_art="
  /\_/\\
 ( o.o )
  > ^ <
"

# в”Ђв”Ђв”Ђ SYSTEM INFO в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
os=$(cat /etc/os-release | grep PRETTY_NAME | cut -d'"' -f2)
kernel=$(uname -r)
hostname=$(hostname)
user=$(whoami)
shell=$(basename $SHELL)
uptime=$(uptime -p | sed 's/up //')
packages=$(pacman -Q 2>/dev/null | wc -l)
memory_total=$(free -h | awk '/^Mem:/ {print $2}')
memory_used=$(free -h | awk '/^Mem:/ {print $3}')
cpu=$(lscpu | grep "Model name" | head -1 | cut -d':' -f2 | xargs)

# в”Ђв”Ђв”Ђ OUTPUT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${cyan}$cat_art${reset}"
echo -e "${bold}${yellow}рџђ± CatboyOS${reset}"
echo -e "${cyan}   OS${reset}       ${white}$os${reset}"
echo -e "${cyan}   Kernel${reset}   ${white}$kernel${reset}"
echo -e "${cyan}   Hostname${reset} ${white}$hostname${reset}"
echo -e "${cyan}   User${reset}     ${white}$user${reset}"
echo -e "${cyan}   Shell${reset}    ${white}$shell${reset}"
echo -e "${cyan}   Uptime${reset}   ${white}$uptime${reset}"
echo -e "${cyan}   Packages${reset} ${white}$packages${reset}"
echo -e "${cyan}   Memory${reset}   ${white}$memory_used / $memory_total${reset}"
echo -e "${cyan}   CPU${reset}      ${white}$cpu${reset}"
echo -e ""
echo -e "${magenta}meow~ рџђѕ${reset}"